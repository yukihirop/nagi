{
  "name": "nagi",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo build",
    "dev": "tsx deploy/ai/host/entry.ts",
    "nagi": "tsx tools/cli/src/index.ts",
    "lint": "turbo lint",
    "spell": "cspell \"**/*.{ts,md}\" --no-progress",
    "test": "turbo test",
    "ui": "pnpm --filter @nagi/ui dev",
    "ui:build": "pnpm --filter @nagi/ui build",
    "ui:preview": "pnpm --filter @nagi/ui preview",
    "ui:server": "pnpm --filter @nagi/ui-server dev",
    "ui:dev": "pnpm --filter @nagi/ui --filter @nagi/ui-server dev",
    "website": "pnpm --filter @nagi/website dev",
    "website:build": "pnpm --filter @nagi/website build",
    "website:preview": "pnpm --filter @nagi/website preview"
  },
  "dependencies": {
    "@nagi/channel-asana": "workspace:*",
    "@nagi/channel-core": "workspace:*",
    "@nagi/channel-discord": "workspace:*",
    "@nagi/channel-discord-embed": "workspace:*",
    "@nagi/channel-slack": "workspace:*",
    "@nagi/channel-slack-block-kit": "workspace:*",
    "@nagi/channel-slack-block-kit-embed": "workspace:*",
    "@nagi/config": "workspace:*",
    "@nagi/logger": "workspace:*",
    "@nagi/orchestrator": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "cspell": "^9.7.0",
    "lefthook": "^2.1.4",
    "tsx": "^4.19.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.0"
  }
}
