# ============================================
# API Tokens (required)
# ============================================
CLAUDE_CODE_OAUTH_TOKEN=
SLACK_APP_TOKEN=
SLACK_BOT_TOKEN=
DISCORD_BOT_TOKEN=
VERCEL_API_TOKEN=
YOUTUBE_API_KEY=

# ============================================
# Asana (optional)
# ============================================
# Personal Access Token from https://app.asana.com/0/my-apps
# ASANA_PAT=
# Comma-separated project gids to watch for @mentions
# ASANA_PROJECT_GIDS=
# Your Asana user gid (optional — auto-resolved via /users/me on connect)
# ASANA_USER_GID=
# Polling interval in ms (default 60000, minimum 10000)
# ASANA_POLL_INTERVAL_MS=60000

# ============================================
# Optional: External Services
# ============================================
# OLLAMA_HOST=

# ============================================
# Optional: Assistant
# ============================================
# ASSISTANT_NAME=Andy
# ASSISTANT_HAS_OWN_NUMBER=false

# ============================================
# Optional: Container Runtime
# ============================================
# CONTAINER_IMAGE=nagi-agent:latest
# CONTAINER_TIMEOUT=1800000
# CONTAINER_MAX_OUTPUT_SIZE=10485760
# IDLE_TIMEOUT=1800000
# MAX_CONCURRENT_CONTAINERS=5
# MAX_AGENT_TURNS=50
# CREDENTIAL_PROXY_PORT=3002

# ============================================
# Optional: Logging & System
# ============================================
# LOG_LEVEL=info
# TZ=Asia/Tokyo
